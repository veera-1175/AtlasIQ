# Copy this file to .env in the repo root before running AtlasIQ.
#
# LLM — required for Query Studio (get a free key at console.groq.com)
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=
LLM_PROVIDER=groq
LLM_MODEL=

# App database (SQLite metadata store)
DATABASE_URL=sqlite:///./data/app.db
JWT_SECRET=change-me-in-production
COMPANY_DATA_KEY=change-company-data-key-in-production-use-32-chars-min

# Redis — required for enterprise: shared cache, rate limits, quotas, async jobs
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Query limits (global defaults; per-company overrides in admin)
MAX_QUERY_ROWS=50000
QUERY_TIMEOUT_SEC=120
RATE_LIMIT_PER_HOUR=200
ASYNC_QUERY_THRESHOLD_SEC=15

# Enterprise mode — warehouse connectors only, no SQLite file uploads
ENTERPRISE_MODE=false
ALLOW_SQLITE_UPLOADS=true

# Schema sampling for large warehouses
SCHEMA_MAX_TABLES_FOR_LLM=12
SCHEMA_MAX_COLUMNS_PER_TABLE=30

# PostgreSQL connection pooling + read replicas
PG_POOL_MIN_CONNECTIONS=1
PG_POOL_MAX_CONNECTIONS=20
PG_POOL_MAX_IDLE_SEC=300
USE_READ_REPLICAS=true

# Per-company quota defaults
DEFAULT_QUOTA_QUERIES_PER_DAY=5000
DEFAULT_QUOTA_MAX_ROWS=50000
DEFAULT_QUOTA_MAX_DATABASES=25
DEFAULT_QUOTA_CONCURRENT_JOBS=10

# Celery worker limits
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=900

# Object storage (S3-compatible — MinIO locally, AWS S3 in production)
OBJECT_STORAGE_ENABLED=false
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=atlasiq
S3_SECRET_KEY=atlasiq-secret
S3_BUCKET=atlasiq-data
S3_REGION=us-east-1

# Horizontal scaling
UVICORN_WORKERS=4
MAX_UPLOAD_MB=100

# Platform super admin (seeded on first startup)
ATLASIQ_SUPER_ADMIN_EMAIL=admin@atlasiq.io
ATLASIQ_SUPER_ADMIN_PASSWORD=AtlasIQ@2026

# Pre-built aggregates refresh interval (hours)
AGGREGATES_AUTO_REFRESH_HOURS=24

# Email notifications (optional — in-app notifications work without SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@atlasiq.io
SMTP_USE_TLS=true
APP_PUBLIC_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
# On Render/Railway/Fly, public URL and CORS are set automatically from RENDER_EXTERNAL_URL etc.

# Report scheduler (disable on secondary API workers in multi-worker deployments)
ENABLE_REPORT_SCHEDULER=true
